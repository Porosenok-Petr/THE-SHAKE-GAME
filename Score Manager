using UnityEngine;
using UnityEngine.UI;

public class ScoreManager : MonoBehaviour
{
    [Header("UI элементы")]
    public Text scoreText;           // Текст счета во время игры

    private int currentScore = 0;

    void Start()
    {
        UpdateScoreUI();
    }

    // Добавить очки
    public void AddScore(int points = 1)
    {
        currentScore += points;
        UpdateScoreUI();
    }

    // Сбросить счет
    public void ResetScore()
    {
        currentScore = 0;
        UpdateScoreUI();
    }

    // Получить текущий счет
    public int GetScore()
    {
        return currentScore;
    }

    // Обновить отображение счета
    private void UpdateScoreUI()
    {
        if (scoreText != null)
        {
            scoreText.text = "Счет: " + currentScore;
        }
    }
}
