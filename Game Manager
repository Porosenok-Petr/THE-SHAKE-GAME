using System.Collections.Generic;
using UnityEngine;
using UnityEngine.UI;

public class GameManager : MonoBehaviour
{
    [Header("Префабы")]
    public GameObject snakeHeadPrefab;
    public GameObject snakeBodyPrefab;
    public GameObject foodPrefab;

    [Header("Настройки")]
    public float moveSpeed = 5f;
    public int startBodyLength = 3;
    public float segmentDistance = 0.8f;

    [Header("UI")]
    public Text gameOverText;
    public Button restartButton;

    [Header("Менеджеры")]
    public ScoreManager scoreManager;

    private GameObject snakeHead;
    private List<GameObject> snakeBody = new List<GameObject>();
    private Vector2 moveDirection = Vector2.right;
    private Vector2 targetDirection = Vector2.right;
    private bool isGameActive = true;

    private List<Vector3> positionsHistory = new List<Vector3>();
    private List<Quaternion> rotationsHistory = new List<Quaternion>();

    void Start()
    {
        // Скрываем UI Game Over
        if (gameOverText != null)
            gameOverText.gameObject.SetActive(false);
        if (restartButton != null)
            restartButton.gameObject.SetActive(false);

        // Сбрасываем счет
        if (scoreManager != null)
        {
            scoreManager.ResetScore();
        }

        // Создаем голову
        snakeHead = Instantiate(snakeHeadPrefab, Vector3.zero, Quaternion.identity);
        snakeHead.name = "SnakeHead";

        // Добавляем обработчик касаний
        SnakeHeadCollision headCollision = snakeHead.AddComponent<SnakeHeadCollision>();
        headCollision.gameManager = this;

        // Создаем тело
        for (int i = 0; i < startBodyLength; i++)
        {
            Vector3 spawnPos = new Vector3(-(i + 1) * segmentDistance * 2f, 0, 0);
            GameObject bodyPart = Instantiate(snakeBodyPrefab, spawnPos, Quaternion.identity);
            bodyPart.name = "SnakeBody_" + i;

            if (bodyPart.GetComponent<Collider2D>() == null)
                bodyPart.AddComponent<BoxCollider2D>();

            snakeBody.Add(bodyPart);
        }

        // Заполняем историю
        positionsHistory.Add(snakeHead.transform.position);
        rotationsHistory.Add(snakeHead.transform.rotation);

        SpawnFood();
    }

    void Update()
    {
        if (!isGameActive) return;

        // Управление
        if (Input.GetKeyDown(KeyCode.RightArrow) && moveDirection != Vector2.left)
            targetDirection = Vector2.right;
        else if (Input.GetKeyDown(KeyCode.LeftArrow) && moveDirection != Vector2.right)
            targetDirection = Vector2.left;
        else if (Input.GetKeyDown(KeyCode.UpArrow) && moveDirection != Vector2.down)
            targetDirection = Vector2.up;
        else if (Input.GetKeyDown(KeyCode.DownArrow) && moveDirection != Vector2.down)
            targetDirection = Vector2.down;
    }

    void FixedUpdate()
    {
        if (!isGameActive || snakeHead == null) return;

        // Плавное направление
        moveDirection = Vector2.Lerp(moveDirection, targetDirection, Time.fixedDeltaTime * 10f);
        moveDirection = moveDirection.normalized;

        // Поворот головы
        if (moveDirection != Vector2.zero)
        {
            float angle = Mathf.Atan2(moveDirection.y, moveDirection.x) * Mathf.Rad2Deg;
            snakeHead.transform.rotation = Quaternion.Euler(0, 0, angle);
        }

        // Сохраняем в историю
        positionsHistory.Insert(0, snakeHead.transform.position);
        rotationsHistory.Insert(0, snakeHead.transform.rotation);

        // Движение головы
        snakeHead.transform.Translate(moveDirection * moveSpeed * Time.fixedDeltaTime, Space.World);

        // Движение тела
        for (int i = 0; i < snakeBody.Count; i++)
        {
            float targetDistance = (i + 1) * segmentDistance;
            Vector3 targetPos = FindPositionInHistory(targetDistance, out Quaternion targetRot);

            if (snakeBody[i] != null)
            {
                snakeBody[i].transform.position = Vector3.Lerp(
                    snakeBody[i].transform.position, targetPos, Time.fixedDeltaTime * moveSpeed * 2f);

                snakeBody[i].transform.rotation = Quaternion.Lerp(
                    snakeBody[i].transform.rotation, targetRot, Time.fixedDeltaTime * moveSpeed * 2f);
            }
        }

        // Ограничение истории
        if (positionsHistory.Count > 500)
        {
            positionsHistory.RemoveAt(positionsHistory.Count - 1);
            rotationsHistory.RemoveAt(rotationsHistory.Count - 1);
        }
    }

    Vector3 FindPositionInHistory(float targetDistance, out Quaternion rotation)
    {
        rotation = Quaternion.identity;
        if (positionsHistory.Count == 0) return snakeHead.transform.position;

        float accumulatedDistance = 0f;

        for (int i = 0; i < positionsHistory.Count - 1; i++)
        {
            float segmentLength = Vector3.Distance(positionsHistory[i], positionsHistory[i + 1]);

            if (accumulatedDistance + segmentLength >= targetDistance)
            {
                float t = (targetDistance - accumulatedDistance) / segmentLength;
                rotation = Quaternion.Lerp(rotationsHistory[i], rotationsHistory[i + 1], t);
                return Vector3.Lerp(positionsHistory[i], positionsHistory[i + 1], t);
            }

            accumulatedDistance += segmentLength;
        }

        rotation = rotationsHistory[rotationsHistory.Count - 1];
        return positionsHistory[positionsHistory.Count - 1];
    }

    public void EatFood(GameObject food)
    {
        if (!isGameActive) return;

        Destroy(food);

        // Добавляем очки
        if (scoreManager != null)
        {
            scoreManager.AddScore(1);
        }

        // Добавляем новый сегмент тела
        Vector3 newBodyPosition = snakeBody.Count > 0 ?
            snakeBody[snakeBody.Count - 1].transform.position : snakeHead.transform.position;

        Quaternion newBodyRotation = snakeBody.Count > 0 ?
            snakeBody[snakeBody.Count - 1].transform.rotation : snakeHead.transform.rotation;

        GameObject newBody = Instantiate(snakeBodyPrefab, newBodyPosition, newBodyRotation);
        newBody.name = "SnakeBody_" + snakeBody.Count;

        if (newBody.GetComponent<Collider2D>() == null)
            newBody.AddComponent<BoxCollider2D>();

        snakeBody.Add(newBody);
        SpawnFood();
    }

    public void GameOver()
    {
        if (!isGameActive) return;

        isGameActive = false;

        // Показываем Game Over UI
        if (gameOverText != null)
            gameOverText.gameObject.SetActive(true);

        if (restartButton != null)
        {
            restartButton.gameObject.SetActive(true);
            restartButton.onClick.RemoveAllListeners();
            restartButton.onClick.AddListener(RestartGame);
        }
    }

    public void RestartGame()
    {
        UnityEngine.SceneManagement.SceneManager.LoadScene(
            UnityEngine.SceneManagement.SceneManager.GetActiveScene().name);
    }

    void SpawnFood()
    {
        float x = Mathf.Round(Random.Range(-8f, 8f));
        float y = Mathf.Round(Random.Range(-4f, 4f));

        // Проверка на занятость позиции
        bool positionTaken = false;

        if (snakeHead != null &&
            Vector3.Distance(snakeHead.transform.position, new Vector3(x, y, 0)) < 0.5f)
            positionTaken = true;

        foreach (GameObject body in snakeBody)
        {
            if (body != null &&
                Vector3.Distance(body.transform.position, new Vector3(x, y, 0)) < 0.5f)
            {
                positionTaken = true;
                break;
            }
        }

        if (positionTaken)
        {
            SpawnFood();
            return;
        }

        GameObject food = Instantiate(foodPrefab, new Vector3(x, y, 0), Quaternion.identity);
        food.name = "Food";
    }
}

public class SnakeHeadCollision : MonoBehaviour
{
    public GameManager gameManager;

    void OnTriggerEnter2D(Collider2D other)
    {
        if (gameManager == null) return;

        if (other.gameObject.CompareTag("Food"))
            gameManager.EatFood(other.gameObject);
        else if (other.gameObject.CompareTag("Wall") ||
                 (other.gameObject.name.StartsWith("SnakeBody") && other.gameObject != this.gameObject))
            gameManager.GameOver();
    }
}
